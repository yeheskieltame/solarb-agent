# SolArb Agent — environment configuration
# Copy this file to .env:  cp .env.example .env

# ══════════════════════════════════════════════════════════════════════════════
# API ENDPOINTS
# ══════════════════════════════════════════════════════════════════════════════

# Polymarket CLOB API (orderbook depth + market discovery)
POLYMARKET_API=https://clob.polymarket.com

# Drift Gateway URL — only needed for live execution
# Scanning uses public APIs (dlob.drift.trade) automatically
# To run your own gateway: https://github.com/drift-labs/gateway
DRIFT_API=http://localhost:8080

# Solana RPC endpoint
SOLANA_RPC=https://api.devnet.solana.com
# For production, use a paid RPC (Helius, QuickNode, etc.):
# SOLANA_RPC=https://your-helius-endpoint.com

# Jupiter V6 swap API
JUPITER_API=https://quote-api.jup.ag/v6

# ══════════════════════════════════════════════════════════════════════════════
# NETWORK
# ══════════════════════════════════════════════════════════════════════════════

# "devnet" or "mainnet"
SOLANA_NETWORK=devnet

# ══════════════════════════════════════════════════════════════════════════════
# AGENT PARAMETERS
# ══════════════════════════════════════════════════════════════════════════════

# Minimum net spread (after fees) to flag an opportunity
# 0.025 = 2.5%  |  0.05 = 5%  |  0.10 = 10%
MIN_NET_SPREAD=0.025

# Maximum USDC per single trade leg
MAX_POSITION_USDC=500

# Total USDC across all open positions
MAX_TOTAL_EXPOSURE_USDC=2000

# Scan interval in seconds (3 = aggressive, 10 = conservative)
SCAN_INTERVAL_SECS=3

# Maximum concurrent open positions
MAX_OPEN_POSITIONS=5

# ══════════════════════════════════════════════════════════════════════════════
# EXECUTION
# ══════════════════════════════════════════════════════════════════════════════

# Dry run mode — logs trades but does NOT send real transactions
# Set to "false" ONLY when you are ready for live trading
DRY_RUN=true

# Take profit: close when price moves this % in our favor (0.03 = 3%)
TAKE_PROFIT_PCT=0.03

# Stop loss: close when price moves this % against us (0.05 = 5%)
STOP_LOSS_PCT=0.05

# Maximum daily loss before agent halts (USDC)
DAILY_LOSS_STOP_USDC=200

# ══════════════════════════════════════════════════════════════════════════════
# WALLET
# ══════════════════════════════════════════════════════════════════════════════

# Path to Solana keypair JSON — only needed for live trading
# WARNING: never commit real keys. Use a dedicated trading wallet.
# AGENT_KEYPAIR_PATH=~/.config/solana/solarb-agent.json

# ══════════════════════════════════════════════════════════════════════════════
# WEBSOCKET
# ══════════════════════════════════════════════════════════════════════════════

# Port for frontend WebSocket connection
WS_PORT=9944

# ══════════════════════════════════════════════════════════════════════════════
# AI STRATEGY PROVIDER
# ══════════════════════════════════════════════════════════════════════════════
#
# The agent uses AI to decide which opportunities to execute and when to close
# positions. Choose one of three providers:
#
# ┌────────────────┬───────────────────────────────────────────────────────────┐
# │ Provider       │ How it works                                             │
# ├────────────────┼───────────────────────────────────────────────────────────┤
# │ claude-cli     │ Uses `claude` CLI binary with your Max subscription.     │
# │  (recommended) │ No API key needed. Just run `claude` once to login.      │
# ├────────────────┼───────────────────────────────────────────────────────────┤
# │ claude         │ Uses Anthropic REST API with a pay-as-you-go API key.    │
# │                │ Requires ANTHROPIC_API_KEY (sk-ant-api03-...).           │
# ├────────────────┼───────────────────────────────────────────────────────────┤
# │ gemini         │ Uses Google Gemini API.                                  │
# │                │ Requires GEMINI_API_KEY.                                 │
# ├────────────────┼───────────────────────────────────────────────────────────┤
# │ (empty)        │ Auto-detect: tries API keys first, falls back to CLI.   │
# └────────────────┴───────────────────────────────────────────────────────────┘

AI_PROVIDER=claude-cli

# ── Claude CLI setup (for AI_PROVIDER=claude-cli) ───────────────────────────
#
# Prerequisites:
#   1. Install Claude Code:  npm install -g @anthropic-ai/claude-code
#   2. Login once:           claude  (follow the prompts)
#   — OR use a setup token:  claude setup-token
#
# No env vars needed — CLI uses its own authenticated session.
#
# Model selection (optional, default: claude-sonnet-4-6):
CLAUDE_MODEL=claude-sonnet-4-6
# Other options:
# CLAUDE_MODEL=claude-haiku-4-5-20251001    # fastest, cheapest
# CLAUDE_MODEL=claude-opus-4-6              # most capable

# ── Claude API setup (for AI_PROVIDER=claude) ──────────────────────────────
#
# Only needed if you prefer pay-as-you-go API over CLI.
# Get your key at: https://console.anthropic.com/settings/keys
#
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
#
# NOTE: OAuth tokens (sk-ant-oat01-...) do NOT work here.
# If you have Claude Max, use AI_PROVIDER=claude-cli instead.

# ── Gemini setup (for AI_PROVIDER=gemini) ───────────────────────────────────
#
# Get your key at: https://aistudio.google.com/apikey
#
# GEMINI_API_KEY=your-gemini-api-key-here

# ══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════════════════════

# RUST_LOG=info    — standard (default)
# RUST_LOG=debug   — per-calculation detail
# RUST_LOG=trace   — maximum verbosity
RUST_LOG=info
