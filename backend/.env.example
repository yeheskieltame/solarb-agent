# SolArb Agent — environment configuration
# Copy this to .env and fill in your values

# ── API endpoints ─────────────────────────────────────────────────────────────
POLYMARKET_API=https://clob.polymarket.com
DRIFT_API=https://mainnet-beta.api.drift.trade
SOLANA_RPC=https://api.devnet.solana.com
JUPITER_API=https://quote-api.jup.ag/v6

# Use a paid RPC for production (much faster, no rate limits)
# SOLANA_RPC=https://your-helius-or-quicknode-endpoint

# ── Network ───────────────────────────────────────────────────────────────────
# "devnet" or "mainnet"
SOLANA_NETWORK=devnet

# ── Agent parameters ──────────────────────────────────────────────────────────

# Minimum net spread (after fees) to flag an opportunity
# 0.025 = 2.5%  |  0.035 = 3.5%  |  0.05 = 5%
MIN_NET_SPREAD=0.025

# Maximum USDC per single trade leg
MAX_POSITION_USDC=500

# Total USDC exposure across all open positions
MAX_TOTAL_EXPOSURE_USDC=2000

# How often to scan in seconds (3 = fast, 10 = conservative)
SCAN_INTERVAL_SECS=3

# Maximum concurrent open positions
MAX_OPEN_POSITIONS=5

# ── Execution ─────────────────────────────────────────────────────────────────

# Dry run mode: logs trades but does not send transactions
# Set to "false" to enable live trading
DRY_RUN=true

# Take profit: close when spread narrows by this % (0.50 = 50% of entry spread)
TAKE_PROFIT_PCT=0.50

# Stop loss: close when spread widens against us by this % (1.00 = 100% of entry spread)
STOP_LOSS_PCT=1.00

# Maximum daily loss before halting (in USDC)
DAILY_LOSS_STOP_USDC=200

# ── Wallet ────────────────────────────────────────────────────────────────────
# WARNING: never commit real keys. Use a dedicated trading keypair with
# only the funds you're willing to deploy.
# AGENT_KEYPAIR_PATH=~/.config/solana/solarb-agent.json

# ── Logging ───────────────────────────────────────────────────────────────────
# RUST_LOG=info       → standard output
# RUST_LOG=debug      → per-calculation detail
# RUST_LOG=trace      → maximum verbosity
RUST_LOG=info
